# ──── Viking Solar – Environment Variables ────
# Copier ce fichier en `.env.local` et remplacer les valeurs par les vôtres

# ── App ──
NEXT_PUBLIC_SITE_URL=https://vickingsolar.com
NEXT_PUBLIC_APP_NAME=Viking Solar
NEXT_PUBLIC_APP_DESCRIPTION="Viking Solar – Votre partenaire en énergie solaire durable à Kinshasa, RDC. Solutions solaires fiables pour particuliers, entreprises et industries."
NEXT_PUBLIC_DEFAULT_LOCALE=fr

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here

# ── Database URL (for migrations/scripts) ──
DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@db.YOUR_PROJECT_ID.supabase.co:5432/postgres

# ── API Rate Limiting ──
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ── Email / SMTP ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=vikingsolar58@gmail.com
SMTP_PASSWORD=your_email_password_or_app_password

# ── Stripe (optional – future billing) ──
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Features Flags ──
NEXT_PUBLIC_ENABLE_AUTH=false
NEXT_PUBLIC_ENABLE_BLOG=false
NEXT_PUBLIC_ENABLE_SHOP=false

# ── Social Links ──
NEXT_PUBLIC_SOCIAL_FACEBOOK=https://www.facebook.com/share/1CiMtZAPkx/?mibextid=wwXIfr
NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://www.instagram.com/vickingsolar58?igsh=MTY3YmIxNDN4NWpzaw==
NEXT_PUBLIC_SOCIAL_TWITTER=https://x.com/vikingsolar?s=21
NEXT_PUBLIC_SOCIAL_TIKTOK=https://www.tiktok.com/@vicking.solar?_r=1&_t=ZS-96lF8PPJJxc

# ── Business Info ──
NEXT_PUBLIC_CONTACT_PHONE=+243820128315
NEXT_PUBLIC_CONTACT_WHATSAPP=https://wa.me/243820128315
NEXT_PUBLIC_CONTACT_EMAIL=vikingsolar58@gmail.com
NEXT_PUBLIC_CONTACT_ADDRESS=Kinshasa, RDC
NEXT_PUBLIC_CONTACT_COUNTRY=RD Congo